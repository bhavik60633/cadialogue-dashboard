# ─── COPY THIS FILE TO .env AND FILL IN YOUR VALUES ─────────────────────
# In production (Render/Railway/VPS) set these as environment variables in
# the host's dashboard, NOT in a committed .env file.

# ── Primary AI: OpenAI GPT-4o ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...your-openai-key
OPENAI_MODEL=gpt-4o
OPENAI_FAST_MODEL=gpt-4o-mini
OPENAI_MONTHLY_USD_CAP=60

# ── Fallback AI: Gemini (auto-used if OpenAI key is missing) ──────────────
GEMINI_API_KEY=AIzaSy...

ANTHROPIC_API_KEY=not-used

# ── Pexels (real stock photos, free 200 req/hr) ───────────────────────────
PEXELS_API_KEY=your-pexels-key

# ── News source ───────────────────────────────────────────────────────────
NEWSAPI_KEY=your-newsapi-key

# ── WordPress publish target ──────────────────────────────────────────────
WP_URL=https://cadialogue.in
WP_USERNAME=your-wp-username
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
WP_SEO_PLUGIN=rankmath

# ── Auth: NextAuth secret (generate with: openssl rand -base64 32) ────────
AUTH_SECRET=replace-with-random-32-bytes
NEXTAUTH_URL=https://dashboard.cadialogue.in

# ── FastAPI sidecar shared token (any random string) ──────────────────────
PIPELINE_SERVICE_TOKEN=replace-with-random-string

# ── Optional integrations (leave empty if unused) ────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_CHANNEL_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
INDEXNOW_KEY=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
